    printf("***** RISCV RELU S8 *****\n\r");
    relu6_riscv_relu6_s8();

    // Run the benchmarks for NN activation s16
    printf("\n\r");
    printf("***** RISCV RELU S16 *****\n\r");
    activ_riscv_nn_activation_s16();

    printf("All tests are passed.\n\r");
    delay_ms(20);
    printf("Finish Activation Functions benchmark\n\r");
    delay_ms(20);
    return 0;
}
