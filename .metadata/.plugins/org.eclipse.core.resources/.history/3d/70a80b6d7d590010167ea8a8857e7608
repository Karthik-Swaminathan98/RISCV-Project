#include "main.h"

void relu6_riscv_relu6_s8(void) {
    const uint16_t input_sizes[] = {512, 1024, 2048};
    const int num_sizes = sizeof(input_sizes) / sizeof(input_sizes[0]);
    clkFastfreq = get_clk_fast_freq();

    for (int i = 0; i < num_sizes; i++) {
        uint16_t size = input_sizes[i];

        // Allocate and initialize the input buffer
        int8_t *input_data = (int8_t *)malloc(size * sizeof(int8_t));
        if (!input_data) {
            printf("Memory allocation failed for size %u\n\r", size);
            continue;
        }

        generate_rand_s8(input_data, size);

        reset_counters();
        fill_stack_pattern_to_sp();
        unsigned int start_cycles, start_inst, end_cycles, end_inst;
        read_perf_counters(&start_cycles, &start_inst);

        // Perform RELU6 operation
        riscv_relu6_s8(input_data, size);

        read_perf_counters(&end_cycles, &end_inst);
        uint32_t cycle_count = end_cycles - start_cycles;
        uint32_t instr_count = end_inst - start_inst;
        uint32_t stack_used = measure_stack_usage();

        float time_sec = (float)cycle_count / clkFastfreq;
        float time_us = time_sec * 1e6f;

        printf("Input Size: %d\n\r", size);
        printf("Cycle Count: %lu\n\r", (unsigned long)cycle_count);
        printf("Instruction Count: %lu\n\r", instr_count);
        printf("Execution Time (approx): %.3f us \n\r", time_us);
        printf("Stack Used: %lu bytes\n\r\n", (unsigned long)stack_used);

        free(input_data);
    }
}
